# Copy to Platform/.env.v1 and replace every change-me value before deployment.

# Public entrypoint.
# For Cloudflare Quick Tunnel, keep this as :80. For a real domain, use https://bot.example.com.
PUBLIC_SITE_ADDRESS=:80
PUBLIC_WEB_ORIGIN=https://replace-with-your-public-url
CORS_ORIGINS=https://replace-with-your-public-url
PASSWORD_RESET_LINK_BASE=https://replace-with-your-public-url/reset-password
ACME_EMAIL=

# Web build values. same-origin keeps API and websocket traffic behind Caddy.
NEXT_PUBLIC_API_BASE=/api/v2
NEXT_PUBLIC_WS_BASE=same-origin

# Database.
POSTGRES_DB=okxbot_v2
POSTGRES_USER=okxbot
POSTGRES_PASSWORD=change-me-postgres-password

# API auth and bootstrap admin.
ACCESS_TOKEN_SECRET=change-me-long-random-access-secret
REFRESH_TOKEN_SECRET=change-me-long-random-refresh-secret
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-password

# Bot event ingestion. Use the same value in Platform/runtime/Execution.env.
EVENT_INGEST_KEY=change-me-long-random-event-ingest-key
EVENT_ALLOW_UNAUTHENTICATED=false
EVENT_PUBLISH_REALTIME=true

# Email is optional for v1. Leave RESEND_API_KEY empty unless password reset email is needed.
EMAIL_PROVIDER=resend
EMAIL_FROM=OKXStatBot <noreply@example.com>
RESEND_API_KEY=
PASSWORD_RESET_RETURN_TOKEN_IN_RESPONSE=false

# Optional pgAdmin profile.
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me-pgadmin-password
